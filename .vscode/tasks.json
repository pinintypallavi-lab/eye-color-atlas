{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install dependencies",
      "type": "shell",
      "command": "pnpm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Eye Color Atlas",
      "type": "shell",
      "command": "pnpm --filter @workspace/eye-color-atlas run dev",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PORT": "5173",
          "BASE_PATH": "/"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:"
        }
      }
    },
    {
      "label": "Run API Server",
      "type": "shell",
      "command": "pnpm --filter @workspace/api-server run dev",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PORT": "8080",
          "NODE_ENV": "development"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Run Full Stack",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
